# Public URL used by Better Auth in local development.
BETTER_AUTH_URL=http://localhost:3000

# Generate a strong value before sharing a real install:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Optional app data root. Defaults to ./data.
# The SQLite database, chats, trails and cover cache live here.
DATA_DIR=./data

# Optional fallback for the books directory before a user chooses one in /settings.
# Prefer configuring the folder in the UI for normal use.
LIBRARY_DIR=./data/books

# Optional Google Books key. Empty works; Open Library is used as fallback.
GOOGLE_BOOKS_API_KEY=

# Optional legacy email delivery. Offline username/password auth does not need this.
RESEND_API_KEY=
AUTH_EMAIL_FROM="Dona Flora <onboarding@resend.dev>"

# Optional local file watcher for Obsidian edits.
# Keep disabled unless you are running locally and want automatic refresh.
DONA_FLORA_LIBRARY_WATCH=0
