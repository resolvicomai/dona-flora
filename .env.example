# Path to the directory containing book Markdown files
# In Docker: /data/books (mounted as volume)
# In local dev: ./data/books
LIBRARY_DIR=./data/books

# Google Books API key (optional, but recommended)
# Without a key, requests are rate-limited aggressively (expect 429/503 under light usage).
# The app falls back to Open Library automatically when Google fails, so this is not required
# for the catalog to work — it just improves search hit rate and latency.
#
# How to obtain:
#   1. Visit https://console.cloud.google.com
#   2. Create (or reuse) a project
#   3. APIs & Services → Library → search "Books API" → Enable
#   4. APIs & Services → Credentials → Create credentials → API key
#   5. Restrict the key to the Books API under "API restrictions" (recommended)
#
# Leave empty or comment out to rely entirely on the Open Library fallback.
GOOGLE_BOOKS_API_KEY=

# AI Librarian (Phase 4) — Claude Sonnet 4.6 via OpenRouter gateway.
# Server-only. NEVER prefix with NEXT_PUBLIC_ (would leak to client bundles).
# Obtain at https://openrouter.ai/keys → Create Key.
# Read implicitly by @openrouter/ai-sdk-provider; no manual process.env reads in server code.
OPENROUTER_API_KEY=

# Model id routed through OpenRouter. Defaults to claude-sonnet-4.6 if unset.
# Other good picks for this use case:
#   google/gemini-3.1-pro-preview   (~33% cheaper, frontier reasoning, 1M context)
#   google/gemini-3-flash-preview   (cheapest competent option, 1M context)
#   x-ai/grok-4.20                  (2M context, $2/$6 per 1M tok)
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
